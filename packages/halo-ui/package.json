{
  "name": "halo-ui",
  "version": "0.1.0",
  "description": "A uni-app Vue 3 UI library with full and on-demand imports.",
  "type": "module",
  "keywords": [
    "uni-app",
    "vue3",
    "typescript",
    "ui",
    "components",
    "mini-program"
  ],
  "license": "MIT",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "style": "./src/styles/index.scss",
  "files": [
    "components",
    "src",
    "services",
    "styles",
    "README.md",
    "CHANGELOG.md",
    "package.json"
  ],
  "sideEffects": [
    "**/*.scss"
  ],
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./components": {
      "types": "./src/components.ts",
      "import": "./src/components.ts"
    },
    "./components/*": {
      "types": "./components/halo-*/index.ts",
      "import": "./components/halo-*/index.ts"
    },
    "./services": {
      "types": "./src/services/index.ts",
      "import": "./src/services/index.ts"
    },
    "./services/*": {
      "types": "./src/services/*.ts",
      "import": "./src/services/*.ts"
    },
    "./styles": "./src/styles/index.scss",
    "./styles/*": "./components/halo-*/style.scss",
    "./theme": "./src/styles/tokens.scss"
  },
  "uni_modules": {
    "displayName": "Halo UI",
    "description": "uni-app Vue 3 UI library with independent component imports.",
    "repository": "",
    "platforms": {
      "cloud": {
        "tcb": "y",
        "aliyun": "y",
        "alipay": "y"
      },
      "client": {
        "App": {
          "app-vue": "y",
          "app-nvue": "n"
        },
        "H5-mobile": {
          "Safari": "y",
          "Android Browser": "y",
          "微信浏览器(Android)": "y",
          "QQ浏览器(Android)": "y"
        },
        "H5-pc": {
          "Chrome": "y",
          "IE": "n",
          "Edge": "y",
          "Firefox": "y",
          "Safari": "y"
        },
        "小程序": {
          "微信": "y",
          "阿里": "y",
          "百度": "y",
          "字节跳动": "y",
          "QQ": "y",
          "快手": "y",
          "京东": "u"
        }
      }
    }
  },
  "scripts": {
    "build": "vite build",
    "lint": "eslint .",
    "test": "vitest run",
    "typecheck": "vue-tsc -p tsconfig.json --noEmit"
  },
  "peerDependencies": {
    "vue": "^3.3.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.0",
    "sass": "^1.77.0",
    "typescript": "^5.5.0",
    "vite": "^6.0.0",
    "vitest": "^2.0.0",
    "vue": "^3.5.0",
    "vue-tsc": "^2.0.0"
  }
}

