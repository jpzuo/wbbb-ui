    "@dcloudio/vite-plugin-uni": "3.0.0-alpha-1000920260626810",
    "sass": "^1.77.0",
    "stylelint": "^16.0.0",
    "typescript": "^5.5.0",
    "vite": "8.1.0",
    "vitest": "^4.1.10",
    "vue": "^3.5.0",
    "vue-tsc": "^2.0.0"
  },
