  "uni_modules": {
    "displayName": "Wbbb UI",
    "description": "uni-app Vue 3 UI library with independent component imports.",
    "repository": "https://github.com/jpzuo/wbbb-ui.git",
    "platforms": {
      "cloud": {
        "tcb": "y",
        "aliyun": "y",
        "alipay": "y"
      },
      "client": {
        "App": {
          "app-vue": "y",
          "app-nvue": "n"
        },
        "H5-mobile": {
          "Safari": "y",
          "Android Browser": "y",
          "WeChat Browser Android": "y",
          "QQ Browser Android": "y"
        },
        "H5-pc": {
          "Chrome": "y",
          "IE": "n",
          "Edge": "y",
          "Firefox": "y",
          "Safari": "y"
        },
        "MiniProgram": {
          "WeChat": "y",
          "Alipay": "y",
          "Baidu": "u",
          "Douyin": "y",
          "QQ": "u",
          "Kuaishou": "u",
          "JD": "u"
        }
      }
    }
  },
  "scripts": {
    "build": "node ../../scripts/build-package.mjs",
    "check:exports": "node ../../scripts/check-exports.mjs",
    "check:tokens": "node ../../scripts/check-design-tokens.mjs",
    "lint": "eslint . --max-warnings 0",
    "lint:styles": "stylelint \"components/**/*.scss\" \"src/**/*.scss\"",
    "prepack": "npm run build",
    "prepublishOnly": "npm run build && npm run check:exports && npm run check:tokens && npm run lint && npm run lint:styles && npm run typecheck && npm run test && npm run test:consumer",
    "release:dry": "npm pack --dry-run --cache ../../.npm-cache",
    "test:consumer": "node ../../scripts/test-package-consumer.mjs",
    "test": "vitest run --no-cache",
    "typecheck": "vue-tsc -p tsconfig.json --noEmit"
  },
  "peerDependencies": {
    "vue": "^3.3.0"
  },
  "devDependencies": {
    "@dcloudio/uni-app": "3.0.0-alpha-1000920260626810",
