{
  "name": "@halo-ui/workspace",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "scripts": {
    "build": "npm run build -w halo-ui",
    "check:exports": "node scripts/check-exports.mjs",
    "dev": "npm run dev:h5 -w @halo-ui/playground",
    "generate:component": "node scripts/create-component.mjs",
    "lint": "npm run lint -w halo-ui",
    "test": "npm run test -w halo-ui",
    "typecheck": "npm run typecheck -w halo-ui"
  },
  "devDependencies": {
    "@dcloudio/uni-app": "^3.0.0",
    "@dcloudio/uni-cli-shared": "^3.0.0",
    "@dcloudio/vite-plugin-uni": "^3.0.0",
    "@types/node": "^22.0.0",
    "@vitejs/plugin-vue": "^5.2.0",
    "eslint": "^9.0.0",
    "sass": "^1.77.0",
    "stylelint": "^16.0.0",
    "typescript": "^5.5.0",
    "vite": "^6.0.0",
    "vitest": "^2.0.0",
    "vue": "^3.5.0",
    "vue-tsc": "^2.0.0"
  }
}

