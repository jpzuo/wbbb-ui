{
  "name": "@halo-ui/workspace",
  "version": "0.1.0-alpha.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "scripts": {
    "build": "npm run build -w halo-ui",
    "check:exports": "node scripts/check-exports.mjs",
    "check:icons": "node scripts/check-icons.mjs",
    "check:playground": "node scripts/check-playground-contract.mjs",
    "check:tokens": "node scripts/check-design-tokens.mjs",
    "dev": "npm run dev:h5 -w @halo-ui/playground",
    "docs:api": "node scripts/generate-api-docs.mjs",
    "generate:icons": "node scripts/generate-icons.mjs",
    "check:api-docs": "node scripts/generate-api-docs.mjs --check",
    "check:accessibility": "node scripts/check-accessibility-contract.mjs",
    "audit:development": "node scripts/audit-development.mjs",
    "audit:production": "npm audit --omit=dev --audit-level=high",
    "check:budgets": "node scripts/check-budgets.mjs",
    "check:budgets:h5": "node scripts/check-budgets.mjs --h5-only",
    "generate:component": "node scripts/create-component.mjs",
    "lint": "npm run lint -w halo-ui",
    "lint:styles": "npm run lint:styles -w halo-ui",
    "prepare:uni-modules": "node scripts/prepare-uni-modules.mjs",
    "release:dry": "npm run release:dry -w halo-ui",
    "test:consumer": "npm run build -w halo-ui && npm run test:consumer -w halo-ui",
    "sync:exports": "node scripts/sync-package-exports.mjs",
    "sync:playground": "node scripts/sync-playground-uni-modules.mjs",
    "test": "npm run test -w halo-ui",
    "test:visual": "npm run build:h5 -w @halo-ui/playground && node scripts/run-visual-tests.mjs",
    "typecheck": "npm run typecheck -w halo-ui"
  },
  "devDependencies": {
    "@dcloudio/uni-app": "3.0.0-alpha-1000920260626810",
    "@dcloudio/uni-cli-shared": "3.0.0-alpha-1000920260626810",
    "@dcloudio/vite-plugin-uni": "3.0.0-alpha-1000920260626810",
    "@eslint/js": "^9.0.0",
    "@playwright/test": "^1.61.1",
    "@react-native-vector-icons/lucide": "^13.1.2",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/test-utils": "^2.4.11",
    "eslint": "^9.0.0",
    "eslint-plugin-vue": "^9.27.0",
    "happy-dom": "^20.10.6",
    "sass": "^1.77.0",
    "stylelint": "^16.0.0",
    "stylelint-config-standard-scss": "^13.0.0",
    "subset-font": "^2.5.0",
    "typescript": "^5.5.0",
    "vite": "8.1.0",
    "vitest": "^4.1.10",
    "vue": "^3.5.0",
    "vue-eslint-parser": "^9.4.0",
    "vue-tsc": "^2.0.0"
  }
}
